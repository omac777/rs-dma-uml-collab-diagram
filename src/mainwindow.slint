import { Button } from "std-widgets.slint";

// Custom button component for the toolbar to use the specific font
component MenuButton inherits Rectangle {
    in property <string> label: "";
    callback clicked;
    
    // Auto-size width based on text content + padding
    width: txt.preferred_width + 24px;
    height: 30px;
    background: #fafafa;
    border-width: 1px;
    border-color: #d0d0d0;
    border-radius: 4px;

    txt := Text {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: parent.height;
        text: label;
        font-family: "Atkinson Hyperlegible Mono";
        font-size: 13px;
        font-weight: 400;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: #222222;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

component MessageLabel inherits Rectangle {
    in-out property <string> msg_seq: "";
    in-out property <string> msg_service: "";
    in-out property <length> msg_x: 0px;
    in-out property <length> msg_y: 0px;
    in-out property <angle> msg_angle: 0deg;
    in-out property <bool> visible_msg: false;

    x: msg_x;
    y: msg_y;
    width: 0px; height: 0px;
    clip: false;

    Rectangle {
        transform-rotation: msg_angle;

        Rectangle {
            x: -layout.preferred-width / 2;
            y: -layout.preferred-height / 2;

            layout := HorizontalLayout {
                spacing: 0px;
                padding: 0px;
                alignment: center;

                Rectangle {
                    background: #2196F3;
                    width: t1.preferred_width + 4px;
                    height: 18px;
                    visible: visible_msg;
                    t1 := Text {
                        text: msg_seq;
                        font-family: "Atkinson Hyperlegible Mono";
                        font-size: 12px;
                        font-weight: 400;
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: #7E57C2;
                    width: t2.preferred_width + 4px;
                    height: 18px;
                    visible: visible_msg;
                    t2 := Text {
                        text: msg_service;
                        font-family: "Atkinson Hyperlegible Mono";
                        font-size: 12px;
                        font-weight: 400;
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    background: #FF9800;
                    width: t3.preferred_width + 4px;
                    height: 18px;
                    visible: visible_msg;
                    t3 := Text {
                        text: "➔";
                        font-family: "Atkinson Hyperlegible Mono";
                        font-size: 11px;
                        font-weight: 400;
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

component ObjectRect inherits Rectangle {
    in-out property <string> obj_id: "";
    in-out property <string> obj_name: "";
    in-out property <length> obj_x: 0px;
    in-out property <length> obj_y: 0px;
    in-out property <bool> visible_obj: false;
    in-out property <int> selection_state: 0;
    in-out property <bool> is_selected: false;

    x: obj_x;
    y: obj_y;
    width: 150px;
    height: 80px;
    background: visible_obj ? #e3f2fd : transparent;
    border-width: visible_obj ? (selection_state > 0 ? 4px : 2px) : 0px;
    border-color: selection_state == 1 ? #42a5f5 :
                  selection_state == 2 ? #1976d2 :
                  selection_state == 3 ? #66bb6a :
                  selection_state == 4 ? #2e7d32 :
                  #1976d2;
    border-radius: 4px;

    Rectangle { visible: selection_state == 2 || selection_state == 4; x: -6px; y: -6px; width: 12px; height: 12px; background: selection_state == 2 ? #1565c0 : #1b5e20; border-radius: 6px; }
    Rectangle { visible: selection_state == 2 || selection_state == 4; x: root.width - 6px; y: -6px; width: 12px; height: 12px; background: selection_state == 2 ? #1565c0 : #1b5e20; border-radius: 6px; }
    Rectangle { visible: selection_state == 2 || selection_state == 4; x: -6px; y: root.height - 6px; width: 12px; height: 12px; background: selection_state == 2 ? #1565c0 : #1b5e20; border-radius: 6px; }
    Rectangle { visible: selection_state == 2 || selection_state == 4; x: root.width - 6px; y: root.height - 6px; width: 12px; height: 12px; background: selection_state == 2 ? #1565c0 : #1b5e20; border-radius: 6px; }

    Text {
        x: 0px;
        y: 0px;
        width: 150px;
        height: 80px;
        text: obj_name;
        font-family: "Atkinson Hyperlegible Mono";
        font-size: 14px;
        font-weight: 400;
        color: #0d47a1;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component AssociationLine inherits Rectangle {
    in-out property <string> assoc_id: "";
    in-out property <length> assoc_x: 0px;
    in-out property <length> assoc_y: 0px;
    in-out property <length> assoc_len: 0px;
    in-out property <angle> assoc_angle: 0deg;
    in-out property <bool> visible_assoc: false;
    in-out property <int> selection_state: 0;

    callback association_line_clicked;

    x: assoc_x;
    y: assoc_y;
    width: assoc_len;
    height: 8px;
    background: transparent;

    Rectangle {
        x: -assoc_len / 2;
        y: 2px;
        width: assoc_len;
        height: 3px;
        background: selection_state == 2 ? #d32f2f :
                    selection_state == 1 ? #1976d2 :
                    (visible_assoc ? #90a4ae : transparent);
        transform-rotation: assoc_angle;
    }

    property <string> clicked_assoc_id: "";
    TouchArea {
        clicked => {
            root.clicked_assoc_id = root.assoc_id;
            root.association_line_clicked();
        }
    }
}

component YellowDebugRect inherits Rectangle {
    in-out property <length> yd_x: 0px;
    in-out property <length> yd_y: 0px;
    in-out property <angle> yd_angle: 0deg;
    in-out property <string> yd_text: "";
    in-out property <bool> yd_visible: false;

    x: yd_x;
    y: yd_y;
    width: 0px;
    height: 0px;
    clip: false;

    Rectangle {
        transform-rotation: yd_angle;
        Rectangle {
            x: -50px;
            y: -9px;
            width: 100px;
            height: 18px;
            background: yellow;
            border-width: 1px;
            border-color: black;
            visible: yd_visible;
            
            Text {
                x: 0px;
                y: 0px;
                width: 100px;
                height: 18px;
                color: black;
                font-family: "Atkinson Hyperlegible Mono";
                font-size: 12px;
                font-weight: 400;
                horizontal-alignment: center;
                vertical-alignment: center;
                text: yd_text;
            }
        }
    }
}

component TypeSelectorDialog inherits Rectangle {
    in-out property <bool> visible_dialog: false;
    in-out property <string> selected_type: "";
    in-out property <string> object_name: "";
    in-out property <int> ingested_types_count: 0;

    in-out property <string> type1_name: "";
    in-out property <string> type2_name: "";
    in-out property <string> type3_name: "";
    in-out property <string> type4_name: "";

    callback confirm;
    callback cancel;
    callback type1_selected;
    callback type2_selected;
    callback type3_selected;
    callback type4_selected;

    x: 0px;
    y: 0px;
    width: 1200px;
    height: 750px;
    background: rgba(0, 0, 0, 100);
    visible: visible_dialog;

    Rectangle {
        x: (parent.width - 400px) / 2;
        y: (parent.height - 300px) / 2;
        width: 400px;
        height: 300px;
        background: white;
        border-width: 2px;
        border-color: #1976d2;
        border-radius: 8px;

        Text {
            x: 15px;
            y: 15px;
            text: "Add Object";
            font-family: "Atkinson Hyperlegible Mono";
            font-size: 18px;
            font-weight: 700;
        }

        Text {
            x: 15px;
            y: 50px;
            text: "Select Type:";
            font-family: "Atkinson Hyperlegible Mono";
            font-size: 14px;
            font-weight: 400;
        }

        Rectangle {
            x: 15px;
            y: 75px;
            width: 370px;
            height: 120px;
            background: white;
            border-width: 1px;
            border-color: #1976d2;
            border-radius: 4px;
            clip: true;

            Rectangle {
                x: 5px; y: 5px; width: 360px; height: 32px;
                background: selected_type == type1_name && type1_name != "" ? #1976d2 : transparent;
                border-radius: 4px;
                visible: type1_name != "";
                Text { x: 10px; y: 8px; text: type1_name; font-family: "Atkinson Hyperlegible Mono"; color: selected_type == type1_name ? white : black; font-size: 13px; font-weight: 400; }
                TouchArea { clicked => { type1_selected(); } }
            }
            Rectangle {
                x: 5px; y: 39px; width: 360px; height: 32px;
                background: selected_type == type2_name && type2_name != "" ? #1976d2 : transparent;
                border-radius: 4px;
                visible: type2_name != "";
                Text { x: 10px; y: 8px; text: type2_name; font-family: "Atkinson Hyperlegible Mono"; color: selected_type == type2_name ? white : black; font-size: 13px; font-weight: 400; }
                TouchArea { clicked => { type2_selected(); } }
            }
            Rectangle {
                x: 5px; y: 73px; width: 360px; height: 32px;
                background: selected_type == type3_name && type3_name != "" ? #1976d2 : transparent;
                border-radius: 4px;
                visible: type3_name != "";
                Text { x: 10px; y: 8px; text: type3_name; font-family: "Atkinson Hyperlegible Mono"; color: selected_type == type3_name ? white : black; font-size: 13px; font-weight: 400; }
                TouchArea { clicked => { type3_selected(); } }
            }
            Rectangle {
                x: 5px; y: 107px; width: 360px; height: 32px;
                background: selected_type == type4_name && type4_name != "" ? #1976d2 : transparent;
                border-radius: 4px;
                visible: type4_name != "";
                Text { x: 10px; y: 8px; text: type4_name; font-family: "Atkinson Hyperlegible Mono"; color: selected_type == type4_name ? white : black; font-size: 13px; font-weight: 400; }
                TouchArea { clicked => { type4_selected(); } }
            }
        }

        Text {
            x: 15px;
            y: 210px;
            text: "Object will be auto-named (type: name)";
            font-family: "Atkinson Hyperlegible Mono";
            font-size: 12px;
            font-weight: 400;
            color: gray;
        }

        Button {
            x: 190px;
            y: 280px;
            text: "Cancel";
            clicked => { cancel(); }
        }
        Button {
            x: 290px;
            y: 280px;
            text: "Add";
            clicked => { confirm(); }
        }
    }
}

export component MainWindow inherits Window {
    width: 1200px;
    height: 750px;
    title: "Rust UML Collaboration Diagram Editor";

    callback new_project;
    callback open_project;
    callback save_project;
    callback add_object;
    callback start_association;
    callback add_message;
    callback type1_clicked;
    callback type2_clicked;
    callback type3_clicked;
    callback type4_clicked;
    callback dialog_confirmed;
    callback dialog_cancelled;
    callback layout_objects;
    callback ingest_sources;
    callback show_sample;
    callback object_clicked(string);
    callback object_hovered(string, bool);
    callback association_clicked(string);
    callback association_line_clicked(string);
    callback endpoints;

    in-out property <length> toolbar_height: 50px;
    in-out property <length> properties_width: 320px;
    in-out property <length> scroll_x: 0px;
    in-out property <length> scroll_y: 0px;
    in-out property <string> selected_id: "";
    in-out property <string> selected_name: "";
    in-out property <string> selected_type: "";
    in-out property <bool> selected_obj_trait: false;
    in-out property <length> selected_obj_x: 0px;
    in-out property <length> selected_obj_y: 0px;
    in-out property <bool> has_selection: false;
    in-out property <bool> creating_association: false;
    in-out property <bool> creating_message: false;
    in-out property <bool> show_type_dialog: false;
    in-out property <string> dialog_selected_type: "";
    in-out property <string> dialog_object_name: "";
    in-out property <int> ingested_types_count: 0;
    in-out property <string> type_selector_type1: "";
    in-out property <string> type_selector_type2: "";
    in-out property <string> type_selector_type3: "";
    in-out property <string> type_selector_type4: "";
    in-out property <string> project_name: "";
    in-out property <string> selected_obj_id: "";
    in-out property <string> selected_obj_name: "";
    in-out property <string> selected_obj_type: "";
    in-out property <length> selected_obj_center_x: 0px;
    in-out property <length> selected_obj_center_y: 0px;

    property <length> divider_width: 6px;
    property <length> scrollbar_size: 20px;
    property <length> canvas_y: toolbar_height;
    property <length> canvas_width: root.width - properties_width - divider_width - scrollbar_size;
    property <length> canvas_height: root.height - toolbar_height - scrollbar_size;

    // Toolbar with custom font buttons
    Rectangle {
        x: 0px; y: 0px; width: root.width - properties_width; height: toolbar_height;
        background: #f5f5f5;
        
        HorizontalLayout {
            padding: 10px;
            spacing: 10px;
            alignment: start;
            
            MenuButton { label: "New"; clicked => { new_project(); } }
            MenuButton { label: "Open"; clicked => { open_project(); } }
            MenuButton { label: "Save"; clicked => { save_project(); } }
            MenuButton { label: "+Object"; clicked => { add_object(); } }
            MenuButton { label: "Association"; clicked => { start_association(); } }
            MenuButton { label: "Message"; clicked => { add_message(); } }
            MenuButton { label: "Layout"; clicked => { layout_objects(); } }
            MenuButton { label: "Ingest Rust"; clicked => { ingest_sources(); } }
            MenuButton { label: "Sample Objects"; clicked => { show_sample(); } }
        }
    }
    Rectangle { x: 0px; y: toolbar_height - 1px; width: root.width - properties_width; height: 1px; background: #cccccc; }

    Rectangle {
        x: 0px; y: canvas_y; width: canvas_width; height: canvas_height;
        background: #ffffff; border-width: 1px; border-color: #cccccc; clip: true;

        Rectangle {
            x: -scroll_x; y: -scroll_y; width: 2000px; height: 2000px; background: #fafafa;

            AssociationLine { assoc_id: "a1"; assoc_x: assoc1_x; assoc_y: assoc1_y; assoc_len: assoc1_len; assoc_angle: assoc1_angle; visible_assoc: assoc1_visible; selection_state: assoc1_selection_state; association_line_clicked => { association_line_clicked(assoc1_id); } }
            AssociationLine { assoc_id: "a2"; assoc_x: assoc2_x; assoc_y: assoc2_y; assoc_len: assoc2_len; assoc_angle: assoc2_angle; visible_assoc: assoc2_visible; }
            AssociationLine { assoc_id: "a3"; assoc_x: assoc3_x; assoc_y: assoc3_y; assoc_len: assoc3_len; assoc_angle: assoc3_angle; visible_assoc: assoc3_visible; }
            AssociationLine { assoc_id: "a4"; assoc_x: assoc4_x; assoc_y: assoc4_y; assoc_len: assoc4_len; assoc_angle: assoc4_angle; visible_assoc: assoc4_visible; }
            AssociationLine { assoc_id: "a5"; assoc_x: assoc5_x; assoc_y: assoc5_y; assoc_len: assoc5_len; assoc_angle: assoc5_angle; visible_assoc: assoc5_visible; }

            ObjectRect { obj_id: obj1_id; obj_name: obj1_name; obj_x: obj1_center_x; obj_y: obj1_center_y; visible_obj: obj1_visible; is_selected: obj1_selected; }
            ObjectRect { obj_id: obj2_id; obj_name: obj2_name; obj_x: obj2_center_x; obj_y: obj2_center_y; visible_obj: obj2_visible; is_selected: obj2_selected; }
            ObjectRect { obj_id: obj3_id; obj_name: obj3_name; obj_x: obj3_center_x; obj_y: obj3_center_y; visible_obj: obj3_visible; is_selected: obj3_selected; }
            ObjectRect { obj_id: obj4_id; obj_name: obj4_name; obj_x: obj4_center_x; obj_y: obj4_center_y; visible_obj: obj4_visible; is_selected: obj4_selected; }
            ObjectRect { obj_id: obj5_id; obj_name: obj5_name; obj_x: obj5_center_x; obj_y: obj5_center_y; visible_obj: obj5_visible; is_selected: obj5_selected; }
            ObjectRect { obj_id: obj6_id; obj_name: obj6_name; obj_x: obj6_center_x; obj_y: obj6_center_y; visible_obj: obj6_visible; is_selected: obj6_selected; }
            ObjectRect { obj_id: obj7_id; obj_name: obj7_name; obj_x: obj7_center_x; obj_y: obj7_center_y; visible_obj: obj7_visible; is_selected: obj7_selected; }
            ObjectRect { obj_id: obj8_id; obj_name: obj8_name; obj_x: obj8_center_x; obj_y: obj8_center_y; visible_obj: obj8_visible; is_selected: obj8_selected; }
            ObjectRect { obj_id: obj9_id; obj_name: obj9_name; obj_x: obj9_center_x; obj_y: obj9_center_y; visible_obj: obj9_visible; is_selected: obj9_selected; }
            ObjectRect { obj_id: obj10_id; obj_name: obj10_name; obj_x: obj10_center_x; obj_y: obj10_center_y; visible_obj: obj10_visible; is_selected: obj10_selected; }

            MessageLabel { msg_seq: msg1_seq; msg_service: msg1_svc; msg_x: msg1_x; msg_y: msg1_y; msg_angle: msg1_angle; visible_msg: msg1_vis; }
            MessageLabel { msg_seq: msg2_seq; msg_service: msg2_svc; msg_x: msg2_x; msg_y: msg2_y; msg_angle: msg2_angle; visible_msg: msg2_vis; }
            MessageLabel { msg_seq: msg3_seq; msg_service: msg3_svc; msg_x: msg3_x; msg_y: msg3_y; msg_angle: msg3_angle; visible_msg: msg3_vis; }
            MessageLabel { msg_seq: msg4_seq; msg_service: msg4_svc; msg_x: msg4_x; msg_y: msg4_y; msg_angle: msg4_angle; visible_msg: msg4_vis; }
            MessageLabel { msg_seq: msg5_seq; msg_service: msg5_svc; msg_x: msg5_x; msg_y: msg5_y; msg_angle: msg5_angle; visible_msg: msg5_vis; }
            MessageLabel { msg_seq: msg6_seq; msg_service: msg6_svc; msg_x: msg6_x; msg_y: msg6_y; msg_angle: msg6_angle; visible_msg: msg6_vis; }
            MessageLabel { msg_seq: msg7_seq; msg_service: msg7_svc; msg_x: msg7_x; msg_y: msg7_y; msg_angle: msg7_angle; visible_msg: msg7_vis; }
            MessageLabel { msg_seq: msg8_seq; msg_service: msg8_svc; msg_x: msg8_x; msg_y: msg8_y; msg_angle: msg8_angle; visible_msg: msg8_vis; }
            MessageLabel { msg_seq: msg9_seq; msg_service: msg9_svc; msg_x: msg9_x; msg_y: msg9_y; msg_angle: msg9_angle; visible_msg: msg9_vis; }

            YellowDebugRect { yd_x: assoc1_top_label_x; yd_y: assoc1_top_label_y; yd_angle: assoc1_angle; yd_text: assoc1_angle / 1deg + " deg"; yd_visible: assoc1_visible; }
            YellowDebugRect { yd_x: assoc2_top_label_x; yd_y: assoc2_top_label_y; yd_angle: assoc2_angle; yd_text: assoc2_angle / 1deg + " deg"; yd_visible: assoc2_visible; }
            YellowDebugRect { yd_x: assoc3_top_label_x; yd_y: assoc3_top_label_y; yd_angle: assoc3_angle; yd_text: assoc3_angle / 1deg + " deg"; yd_visible: assoc3_visible; }
            YellowDebugRect { yd_x: assoc4_top_label_x; yd_y: assoc4_top_label_y; yd_angle: assoc4_angle; yd_text: assoc4_angle / 1deg + " deg"; yd_visible: assoc4_visible; }
            YellowDebugRect { yd_x: assoc5_top_label_x; yd_y: assoc5_top_label_y; yd_angle: assoc5_angle; yd_text: assoc5_angle / 1deg + " deg"; yd_visible: assoc5_visible; }
        }
    }

    Rectangle { x: 0px; y: canvas_y + canvas_height; width: canvas_width; height: scrollbar_size; background: #f5f5f5; border-width: 1px; border-color: #cccccc; Rectangle { x: 10px + scroll_x / 10; y: 2px; width: 150px; height: 16px; background: #bdbdbd; border-radius: 3px; } TouchArea { x: canvas_width / 2; width: canvas_width / 2; height: scrollbar_size; clicked => { scroll_x = (scroll_x + 100px).min(1800px); } } TouchArea { width: canvas_width / 2; height: scrollbar_size; clicked => { scroll_x = (scroll_x - 100px).max(0px); } } }
    Rectangle { x: canvas_width; y: canvas_y; width: scrollbar_size; height: canvas_height; background: #f5f5f5; border-width: 1px; border-color: #cccccc; Rectangle { x: 2px; y: 10px + scroll_y / 10; width: 16px; height: 150px; background: #bdbdbd; border-radius: 3px; } TouchArea { x: scrollbar_size; y: canvas_height / 2; width: scrollbar_size; height: canvas_height / 2; clicked => { scroll_y = (scroll_y + 100px).min(1800px); } } TouchArea { x: scrollbar_size; height: canvas_height / 2; width: scrollbar_size; clicked => { scroll_y = (scroll_y - 100px).max(0px); } } }
    Rectangle { x: canvas_width; y: toolbar_height; width: divider_width; height: canvas_height; background: #e0e0e0; }

    Rectangle {
        x: root.width - properties_width; y: toolbar_height; width: properties_width; height: root.height - toolbar_height;
        background: #fafafa; border-width: 1px; border-color: #cccccc;
        Text { x: 15px; y: 15px; text: "Properties"; font-family: "Atkinson Hyperlegible Mono"; font-size: 16px; font-weight: 700; color: #212121; }
        Text { x: 15px; y: 50px; text: "Selected: " + (selected_id != "" ? selected_name : "None"); font-family: "Atkinson Hyperlegible Mono"; font-size: 13px; font-weight: 400; color: #424242; }
        Text { x: 15px; y: 85px; text: "Type: " + selected_type; font-family: "Atkinson Hyperlegible Mono"; font-size: 13px; font-weight: 400; color: #424242; }
        Rectangle { x: 15px; y: 120px; width: properties_width - 30px; height: 1px; background: #e0e0e0; }
        Text { x: 15px; y: 140px; text: "Note: Yellow boxes show association angles"; font-family: "Atkinson Hyperlegible Mono"; font-size: 11px; font-weight: 400; color: #757575; }
    }

    TypeSelectorDialog {
        visible_dialog: show_type_dialog;
        selected_type: dialog_selected_type;
        object_name: dialog_object_name;
        type1_name: type_selector_type1;
        type2_name: type_selector_type2;
        type3_name: type_selector_type3;
        type4_name: type_selector_type4;
        confirm => { dialog_confirmed(); }
        cancel => { dialog_cancelled(); }
        type1_selected => { type1_clicked(); }
        type2_selected => { type2_clicked(); }
        type3_selected => { type3_clicked(); }
        type4_selected => { type4_clicked(); }
    }

    property <string> dialog_internal_type: "";

